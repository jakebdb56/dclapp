VESSELFINDER_API_KEY=your_vesselfinder_api_key_here
# Optional: include satellite positions when they are newer than terrestrial positions.
VESSELFINDER_INCLUDE_SATELLITE=false
# Optional: only return positions newer than this many minutes.
VESSELFINDER_INTERVAL_MINUTES=
# Optional: set to false to disable the hourly Disney Destiny details-page scrape.
VESSELFINDER_DETAILS_SCRAPE=true
PORT=3000
